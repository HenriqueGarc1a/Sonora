{
  "manifest_version": 3,
  "name": "Sonora — Controle de Áudio",
  "version": "0.5.0",
  "description": "Controle volume, velocidade, pitch, equalização, reverb e imagem estéreo na aba atual.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "src/runtime/background.js",
    "scripts": ["src/runtime/background.js"]
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_popup": "src/popup/index.html",
    "default_title": "Abrir Sonora"
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/audio/stereo-width-processor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "sonora@example.com"
    }
  }
}
