{
  "compilerOptions": {
    "target": "ES2020",
    "module": "preserve",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2020"],
    "jsx": "react",
    "strict": true,
    "skipLibCheck": true,
    "removeComments": false,
    "rootDir": "src/popup",
    "outDir": "dist/src/popup"
  },
  "include": ["src/popup/**/*.ts", "src/popup/**/*.tsx"]
}
